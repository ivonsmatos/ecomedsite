# EcoMed Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais

# ─── Geral ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de Dados ──────────────────────────────────────────
# Supabase: Settings → Database → Connection String (URI)
DATABASE_URL="postgresql://postgres:[SENHA]@db.[ID].supabase.co:5432/postgres"

# ─── Redis ───────────────────────────────────────────────────
# Upstash: console.upstash.com → Redis → Connect → .env
REDIS_URL="rediss://:[TOKEN]@[HOST].upstash.io:6379"

# ─── JWT ─────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="seu_jwt_secret_muito_longo_e_aleatorio_aqui"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ─── CORS ────────────────────────────────────────────────────
# Em produção: https://ecomed.com.br,https://www.ecomed.com.br
CORS_ORIGINS="http://localhost:5173"

# ─── Google OAuth ────────────────────────────────────────────
# console.cloud.google.com → APIs & Serviços → Credenciais
GOOGLE_CLIENT_ID="seu_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# ─── E-mail (SendGrid) ───────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxx"
EMAIL_FROM="noreply@ecomed.com.br"

# ─── Web Push (VAPID) ────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="seu_vapid_public_key"
VAPID_PRIVATE_KEY="seu_vapid_private_key"

# ─── Cloudflare R2 (Upload de Imagens) ───────────────────────
R2_ACCOUNT_ID="seu_account_id_cloudflare"
R2_ACCESS_KEY_ID="seu_r2_access_key"
R2_SECRET_ACCESS_KEY="seu_r2_secret_key"
R2_BUCKET_NAME="ecomed-uploads"
R2_PUBLIC_URL="https://uploads.ecomed.com.br"

# ─── Ollama (IA / RAG) ────────────────────────────────────────
# Dev local: http://localhost:11434/v1
# Prod (Hetzner): http://[SERVIDOR_IP]:11434/v1
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_CHAT_MODEL="qwen3:8b"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# ─── Chat — System Prompt (opcional, tem padrão no código) ───
# ECOMED_SYSTEM_PROMPT="Você é o Assistente EcoMed..."
